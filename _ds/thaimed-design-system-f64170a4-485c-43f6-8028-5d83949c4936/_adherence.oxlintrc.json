{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "ui_kits/thaimed_app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:JetBrains Mono|Sarabun))/i]",
        "message": "Font not provided by the design system. Available: JetBrains Mono, Sarabun."
      },
      {
        "selector": "JSXOpeningElement[name.name='AlertWarning'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|title|description|items|onTransfer|onDismiss|key|ref|className|style|children)$/]",
        "message": "<AlertWarning> doesn't accept that prop. Declared props: level, title, description, items, onTransfer, onDismiss."
      },
      {
        "selector": "JSXOpeningElement[name.name='AlertWarning'] > JSXAttribute[name.name='level'] > Literal[value!=/^(?:caution|warning|danger)$/]",
        "message": "<AlertWarning> level must be one of 'caution' | 'warning' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|onClick|icon|trailingIcon|fullWidth|type|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, onClick, icon, trailingIcon, fullWidth, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger|ghost-danger|warning|transfer|success)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger' | 'ghost-danger' | 'warning' | 'transfer' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PatientCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:queueNumber|hn|name|age|gender|services|status|waitTime|onClick|onCallQueue|compact|key|ref|className|style|children)$/]",
        "message": "<PatientCard> doesn't accept that prop. Declared props: queueNumber, hn, name, age, gender, services, status, waitTime, onClick, onCallQueue, compact."
      },
      {
        "selector": "JSXOpeningElement[name.name='PatientCard'] > JSXAttribute[name.name='gender'] > Literal[value!=/^(?:male|female|other)$/]",
        "message": "<PatientCard> gender must be one of 'male' | 'female' | 'other'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PatientCard'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:waiting|active|done|followup|referred|danger|cancelled)$/]",
        "message": "<PatientCard> status must be one of 'waiting' | 'active' | 'done' | 'followup' | 'referred' | 'danger' | 'cancelled'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|size|onClick|key|ref|className|style|children)$/]",
        "message": "<ServiceTag> doesn't accept that prop. Declared props: type, size, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceTag'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:exam|medicine|massage|compress|steam|soak|poultice|postpartum|community|advice)$/]",
        "message": "<ServiceTag> type must be one of 'exam' | 'medicine' | 'massage' | 'compress' | 'steam' | 'soak' | 'poultice' | 'postpartum' | 'community' | 'advice'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceTag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<ServiceTag> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|size|showDot|pulse|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: status, size, showDot, pulse."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:waiting|active|done|followup|referred|cancelled|danger)$/]",
        "message": "<StatusBadge> status must be one of 'waiting' | 'active' | 'done' | 'followup' | 'referred' | 'cancelled' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<StatusBadge> size must be one of 'sm' | 'md' | 'lg'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
